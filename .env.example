DB_HOST=localhost
DB_USER=admin
DB_PASSWORD=changeme
DB_NAME=vokrub
DB_PORT=5432
JWT_SECRET=changeme

# Frontend URL (used for OAuth redirect after login)
APP_URL=http://localhost:8081

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/api/customer/auth/oauth/google/callback

# Facebook OAuth — https://developers.facebook.com/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URL=http://localhost:3000/api/customer/auth/oauth/facebook/callback

# SMS_KUB — phone OTP (leave empty to use console-log mode in dev)
SMSKUB_API_KEY=
SMSKUB_SENDER=Vokrub

# docker compose vars
BUILD_ENV=production
HOST_PORT=3000
ENV_FILE=.env

# Discord webhook — new-customer registration alerts (leave empty to disable)
DISCORD_WEBHOOKS_LINK=
